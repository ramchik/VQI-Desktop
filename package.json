{
  "name": "vqi-desktop",
  "version": "1.0.0",
  "description": "Vascular Surgery Patient Registry - VQI Style Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run webpack:watch\" \"wait-on dist/bundle.js && electron .\"",
    "webpack:watch": "webpack --watch --mode development",
    "webpack:build": "webpack --mode production",
    "build": "npm run webpack:build",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-rebuild": "^3.2.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.1",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "com.vascular.registry",
    "productName": "VQI Desktop Registry",
    "files": ["dist/**/*", "main.js", "preload.js", "src/index.html"],
    "win": {
      "target": "nsis"
    }
  }
}
